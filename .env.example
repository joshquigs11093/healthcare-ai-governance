# healthcare-ai-governance configuration (.spec §8)
# Copy to .env and adjust. All values have sensible defaults.

INVENTORY_DIR=./inventory
ARTIFACTS_DIR=./artifacts

# LLM provider for the output auditor's LLM-as-judge checks: anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Footer label stamped on generated PDFs
PDF_CLASSIFICATION_LABEL=Internal Use Only

LOG_LEVEL=INFO
